# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/uvideo"

# Supabase client auth
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
VITE_AUTH_REDIRECT_URL="https://your-vercel-domain.vercel.app/auth"

# Supabase server auth verification (Vercel serverless /api)
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# AWS S3 uploads and CloudFront playback
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-uvideo-upload-bucket"
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
CLOUDFRONT_BASE_URL="https://your-cloudfront-domain.cloudfront.net"

# Didit verification
DIDIT_VERIFICATION_URL="https://verification.didit.me/..."
DIDIT_WEBHOOK_SECRET="your-didit-webhook-secret"

# API CORS (set to your Vercel app origin in production)
CORS_ORIGIN="https://your-vercel-domain.vercel.app"
