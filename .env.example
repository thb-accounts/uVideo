VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
VITE_AUTH_REDIRECT_URL="https://your-vercel-domain.vercel.app/auth"

# Server-side Supabase access for Express upload routes and Bunny webhooks.
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY=""

# Primary Bunny Stream uploads. API keys are server-side only; never expose as VITE_*.
BUNNY_STREAM_LIBRARY_ID=""
BUNNY_STREAM_API_KEY=""
BUNNY_STREAM_CDN_HOST="vz-YOUR-LIBRARY.b-cdn.net"
BUNNY_STREAM_WEBHOOK_READ_ONLY_KEY=""
MAX_VIDEO_UPLOAD_BYTES="524288000"

# Automatic Cloudinary fallback. The API secret stays server-side only.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="simplichill/videos"
